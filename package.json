{
  "name": "webhookmail",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run test/db.test.js test/ratelimit.test.js test/stripe.test.js",
    "test:integration": "vitest run test/api.test.js",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "hono": "^4.0.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "vitest": "^1.6.1",
    "wait-on": "^8.0.3"
  }
}
